# arah — Environment Configuration
# Copy this file to .env and fill in your values.

# ── Hermes Stack ──────────────────────────────────────────
HERMES_API_KEY=change_me_generate_random_key
HERMES_WEBHOOK_URL=http://localhost:8080/webhook

# ── CostForge ──────────────────────────────────────────────
COSTFORGE_API_URL=http://costforge:8000
COSTFORGE_API_KEY=change_me_costforge_key

# ── NOC Dashboard ──────────────────────────────────────────
NOC_DASHBOARD_PORT=3000
NOC_API_PORT=8080

# ── Honcho (Memory Layer) ──────────────────────────────────
HONCHO_DB_PASSWORD=change_me_db_password
HONCHO_TOKEN=change_me_honcho_token

# ── Ollama ─────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
